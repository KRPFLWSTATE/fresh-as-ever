# Copy to .env.local for local dev. In production, set these in Vercel → Project → Settings → Environment Variables.

# Supabase (use staging project for preview; production project for Production only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — required for PayHere webhook + merchant staff invite + pickup cron
SUPABASE_SERVICE_ROLE_KEY=
# Optional: new Supabase default JSON secret bundle (service_role key inside)
# SUPABASE_SECRET_KEYS={"service_role":"eyJ..."}

# Vercel Cron — pickup reminder SMS route
CRON_SECRET=

# Google Maps (location API routes). Prefer server-only GOOGLE_MAPS_API_KEY on Vercel.
GOOGLE_MAPS_API_KEY=
# Optional public alias (restrict key by HTTP referrer in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# PayHere (sandbox or live). Merchant ID is public; secret is server-only.
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=
PAYHERE_SECRET=
# PayHere Refund API (OAuth app credentials — server-only)
PAYHERE_APP_ID=
PAYHERE_APP_SECRET=
PAYHERE_API_BASE=https://sandbox.payhere.lk

# Never set in production
# TESTING_ENV=1

# Multi-bag group reservations (discover cart + create_group_reservation). Literal `true` enables.
# NEXT_PUBLIC_GROUP_RESERVATIONS_ENABLED=true

# Clearance Shelf (supermarket item-level listings). Literal `true` enables in prod.
# Unset defaults to enabled in `next dev`. Restart dev server after changing.
# NEXT_PUBLIC_CLEARANCE_SHELVES_ENABLED=true

# Copy to .env.local for local dev. In production, set these in Vercel → Project → Settings → Environment Variables.

# Supabase (use staging project for preview; production project for Production only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — required for PayHere webhook + merchant staff invite
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps (location API routes). Prefer server-only GOOGLE_MAPS_API_KEY on Vercel.
GOOGLE_MAPS_API_KEY=
# Optional public alias (restrict key by HTTP referrer in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# PayHere (sandbox or live). Merchant ID is public; secret is server-only.
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=
PAYHERE_SECRET=

# Never set in production
# TESTING_ENV=1

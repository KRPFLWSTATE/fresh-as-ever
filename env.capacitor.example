# Copy values into `.env.local` (gitignored). Used when running `npm run cap:sync`.
#
# LAN dev: bind Next with `npm run dev:lan`, then set URL to your machine IP, e.g.:
# CAPACITOR_SERVER_URL=http://192.168.1.10:3000
# CAPACITOR_ANDROID_CLEARTEXT=true
#
# Production / preview HTTPS (cleartext off — omit CAPACITOR_ANDROID_CLEARTEXT):
# CAPACITOR_SERVER_URL=https://your-deployment.vercel.app
#
# Optional: comma-separated extra hosts for server.allowNavigation
# CAPACITOR_EXTRA_ALLOW_NAVIGATION=cdn.example.com,*.example.com

CAPACITOR_SERVER_URL=
CAPACITOR_ANDROID_CLEARTEXT=true
